# Required
DATABASE_URL=postgresql+asyncpg://atis:atis@localhost:5432/atis
REDIS_URL=redis://localhost:6379/0
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_PROGRAM_ID=

# Agent loop
AGENT_LOOP_INTERVAL_SECONDS=30

# FastAPI
CORS_ORIGINS=http://localhost:5173
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Redis TTL
REDIS_CACHE_TTL_SECONDS=35

# Claude API
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096   # Communication Agent calls only.
                         # Standup summary + escalation memo
                         # require headroom. Do not lower below 2048.
